# ──────────────────────────────────────────────
# ZapCatálogo — Variáveis de Ambiente (Backend)
# Crie uma cópia chamada .env e preencha os valores
# ──────────────────────────────────────────────

# Ambiente
NODE_ENV=development
PORT=3001

# ── Frontend ──
# URL do seu frontend (Vercel) — usada no CORS e links
FRONTEND_URL=http://localhost:3000
# CORS: origens adicionais separadas por vírgula
CORS_ORIGIN=http://localhost:3000

# ── Upload ──
MAX_FILE_SIZE=10485760

# ── Neon PostgreSQL (banco de dados) ──
DATABASE_URL=postgresql://usuario:senha@host/neondb?sslmode=require

# ── Supabase Storage (armazenamento de imagens) ──
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_KEY=sua-service-key

# ── JWT (autenticação) ──
JWT_SECRET=uma-chave-secreta-forte-aqui

# ── Mercado Pago (pagamentos) ──
MP_ACCESS_TOKEN=seu-access-token
MP_PUBLIC_KEY=sua-public-key
MP_WEBHOOK_URL=https://seu-backend.onrender.com/api/payment/webhook

# ── URL base (para links públicos do catálogo) ──
BASE_URL=http://localhost:3000